---
title: "Pioneer Portal"
description: "Private pioneer resources for Fight for Manhood."
layout: "base.njk"
permalink: "/pioneers/"
eleventyExcludeFromCollections: true
robots: noindex
---

<style>
:root{
  --bg0:#070b12;
  --bg1:#0b1324;
  --card:rgba(255,255,255,.05);
  --card2:rgba(255,255,255,.07);
  --text:#e8edf6;
  --muted:#a9b3c7;
  --gold:#caa246;
  --line:rgba(202,162,70,.28);
  --stroke:rgba(255,255,255,.10);
  --danger:#ffb4b4;
}
.ffm-gate-lock{ overflow:hidden; }
.ffm-gate-wrap{ position:fixed; inset:0; z-index:9999; }
.ffm-gate-backdrop{
  position:absolute; inset:0; background:rgba(3,7,14,.82); backdrop-filter:blur(8px);
}
.ffm-gate-box{
  position:relative; z-index:2; width:min(92vw,520px); margin:12vh auto 0; padding:34px 28px;
  border:1px solid var(--line); border-radius:24px;
  background:linear-gradient(180deg, rgba(9,16,28,.96), rgba(7,11,18,.96));
  box-shadow:0 20px 70px rgba(0,0,0,.45); color:var(--text); text-align:center;
}
.ffm-gate-kicker{
  color:var(--gold); letter-spacing:.14em; text-transform:uppercase; font-size:.82rem; margin-bottom:10px;
}
.ffm-gate-box h1{ margin:0 0 10px; font-size:2rem; line-height:1.08; }
.ffm-gate-box p{ margin:0 0 18px; color:var(--muted); }
.ffm-gate-form{ display:grid; gap:12px; }
.ffm-gate-input{
  width:100%; padding:14px 16px; border-radius:14px; border:1px solid var(--stroke);
  background:rgba(255,255,255,.06); color:var(--text); font-size:1rem;
}
.ffm-gate-btn{
  border:none; border-radius:14px; padding:14px 18px;
  background:linear-gradient(180deg, #d2ab52, #b78d35);
  color:#111; font-weight:800; letter-spacing:.06em; text-transform:uppercase; cursor:pointer;
}
.ffm-gate-error{ color:var(--danger); font-size:.95rem; }
.ffm-page{
  min-height:100vh; color:var(--text);
  background:radial-gradient(1000px 500px at 50% -10%, rgba(255,255,255,.08), transparent 60%), linear-gradient(180deg, var(--bg1), var(--bg0));
}
.ffm-shell{ width:min(1180px, calc(100% - 32px)); margin:0 auto; padding:42px 0 80px; }
.ffm-hero{
  padding:34px 28px; border:1px solid var(--line); border-radius:28px;
  background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.03));
  box-shadow:0 10px 30px rgba(0,0,0,.18); margin-bottom:22px;
}
.ffm-kicker{
  color:var(--gold); text-transform:uppercase; letter-spacing:.14em; font-size:.82rem; margin-bottom:10px;
}
.ffm-hero h1{ margin:0 0 10px; font-size:clamp(2rem, 4vw, 3.5rem); line-height:1.02; }
.ffm-hero p{ margin:0; color:var(--muted); max-width:760px; font-size:1.05rem; }
.ffm-grid{ display:grid; grid-template-columns:1.1fr .9fr; gap:22px; margin-top:22px; }
.ffm-stack{ display:grid; gap:22px; }
.ffm-card{
  border:1px solid var(--stroke); border-radius:24px; background:var(--card); padding:24px;
  box-shadow:0 10px 30px rgba(0,0,0,.16);
}
.ffm-card h2{ margin:0 0 14px; font-size:1.35rem; }
.ffm-card p{ color:var(--muted); }
.ffm-list{ display:grid; gap:12px; }
.ffm-item{
  border:1px solid rgba(255,255,255,.08); border-radius:18px; padding:16px; background:var(--card2);
}
.ffm-item strong{ display:block; margin-bottom:4px; }
.ffm-item span{ color:var(--muted); font-size:.96rem; }
.ffm-links{ display:grid; gap:12px; }
.ffm-link{
  display:block; text-decoration:none; color:var(--text); padding:16px 18px; border-radius:18px;
  border:1px solid rgba(202,162,70,.22); background:rgba(202,162,70,.07);
  transition:transform .15s ease, border-color .15s ease, background .15s ease;
}
.ffm-link:hover{
  transform:translateY(-1px); border-color:rgba(202,162,70,.44); background:rgba(202,162,70,.11);
}
.ffm-link strong{ display:block; margin-bottom:4px; }
.ffm-link span{ color:var(--muted); font-size:.95rem; }
.ffm-note{ border-left:3px solid var(--gold); padding-left:14px; color:var(--muted); }
.ffm-post{ border-top:1px solid rgba(255,255,255,.08); padding-top:16px; margin-top:16px; }
.ffm-post:first-of-type{ border-top:none; padding-top:0; margin-top:0; }
.ffm-post h3{ margin:0 0 8px; font-size:1.05rem; }
.ffm-post-meta{
  color:var(--gold); font-size:.84rem; letter-spacing:.08em; text-transform:uppercase; margin-bottom:8px;
}
@media (max-width: 900px){
  .ffm-grid{ grid-template-columns:1fr; }
}
</style>

{% set gateId = "pioneers" %}
{% set gateTitle = pioneerPortal.heroTitle %}
{% set gateMessage = "Private access for pioneers and leadership support." %}
{% set gatePassword = pioneerPortal.password %}
{% include "partials/ffm-gate.njk" %}

<section class="ffm-page">
  <div class="ffm-shell">

    <div class="ffm-hero">
      <div class="ffm-kicker">{{ pioneerPortal.heroKicker }}</div>
      <h1>{{ pioneerPortal.heroTitle }}</h1>
      <p>{{ pioneerPortal.heroText }}</p>
    </div>

    <div class="ffm-grid">
      <div class="ffm-stack">

        <div class="ffm-card">
          <h2>This Week</h2>
          <div class="ffm-list">
            {% for item in pioneerPortal.thisWeek %}
              <div class="ffm-item">
                <strong>{{ item.title }}</strong>
                <span>{{ item.text }}</span>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class="ffm-card">
          <h2>Posts From You</h2>
          {% for post in pioneerPortal.posts %}
            <div class="ffm-post">
              <div class="ffm-post-meta">{{ post.meta }}</div>
              <h3>{{ post.title }}</h3>
              <p>{{ post.text }}</p>
            </div>
          {% endfor %}
        </div>

      </div>

      <div class="ffm-stack">

        <div class="ffm-card">
          <h2>Review Materials</h2>
          <div class="ffm-links">
            {% for item in pioneerPortal.reviewMaterials %}
              <a class="ffm-link" href="{{ item.url }}" target="_blank" rel="noopener">
                <strong>{{ item.title }}</strong>
                <span>{{ item.text }}</span>
              </a>
            {% endfor %}
          </div>
        </div>

        <div class="ffm-card">
          <h2>Attendee Contact List</h2>
          <div class="ffm-links">
            <a class="ffm-link" href="{{ pioneerPortal.contactList.url }}" target="_blank" rel="noopener">
              <strong>{{ pioneerPortal.contactList.title }}</strong>
              <span>{{ pioneerPortal.contactList.text }}</span>
            </a>
          </div>
          <p class="ffm-note">{{ pioneerPortal.contactList.note }}</p>
        </div>

        <div class="ffm-card">
          <h2>Quick Downloads</h2>
          <div class="ffm-links">
            {% for item in pioneerPortal.downloads %}
              <a class="ffm-link" href="{{ item.url }}" target="_blank" rel="noopener">
                <strong>{{ item.title }}</strong>
                <span>{{ item.text }}</span>
              </a>
            {% endfor %}
          </div>
        </div>

      </div>
    </div>

  </div>
</section>
